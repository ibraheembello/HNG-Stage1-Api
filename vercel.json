{
  "version": 2,
  "builds": [
    {
      "src": "api/main.ts",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/main.ts" },
    { "source": "/((?!api/).*)", "destination": "/frontend/$1" }
  ]
}
